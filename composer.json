{
  "name": "xul/auth-kit",
  "description": "Reusable Laravel auth kit package with Blade UI, themes, email verification, 2FA, password reset, and rate limiting.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "auth",
    "authentication",
    "2fa",
    "email-verification",
    "password-reset",
    "blade",
    "package"
  ],
  "homepage": "https://github.com/Xultech-LTD/auth-kit",
  "support": {
    "issues": "https://github.com/Xultech-LTD/auth-kit/issues",
    "source": "https://github.com/Xultech-LTD/auth-kit"
  },
  "authors": [
    {
      "name": "Michael Erastus",
      "homepage": "https://github.com/michaelerastus"
    },
    {
      "name": "Xultech LTD",
      "homepage": "https://github.com/Xultech-LTD"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/auth": "^12.0|^13.0",
    "illuminate/cache": "^12.0|^13.0",
    "illuminate/contracts": "^12.0|^13.0",
    "illuminate/events": "^12.0|^13.0",
    "illuminate/http": "^12.0|^13.0",
    "illuminate/notifications": "^12.0|^13.0",
    "illuminate/queue": "^12.0|^13.0",
    "illuminate/routing": "^12.0|^13.0",
    "illuminate/session": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/validation": "^12.0|^13.0",
    "illuminate/view": "^12.0|^13.0",
    "bacon/bacon-qr-code": "^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.11|^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Xul\\AuthKit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Xul\\AuthKit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Xul\\AuthKit\\AuthKitServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}